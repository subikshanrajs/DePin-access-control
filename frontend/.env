# DePIN Access Protocol — Frontend Environment Variables
# Copy to .env.local and fill in values

# Contract addresses (from deployments/latest.json after running forge deploy)
VITE_GATEWAY_ADDRESS_TESTNET=0xef7cc55FE427e43c55Ee6Ba0f86B5016F1a6Dd4b
VITE_REGISTRY_ADDRESS_TESTNET=0x93AC75501554B258ccd9b6a55D5e8CfE95198572

VITE_GATEWAY_ADDRESS_MAINNET=0xYourMainnetGatewayAddress
VITE_REGISTRY_ADDRESS_MAINNET=0xYourMainnetRegistryAddress

# WalletConnect Project ID (from https://cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=your_project_id_here