		"devdoc": {
			"details": "Implementations must emit the required events and implement all functions",
			"events": {
				"AccessGranted(address,bytes32,uint256,uint256,uint256)": {
					"params": {
						"amountPaid": "ETH paid in wei",
						"deviceId": "Off-chain identifier (MAC address hash, device fingerprint)",
						"expiresAt": "Block timestamp when access expires",
						"tierId": "The pricing tier selected",
						"user": "The wallet address purchasing access"
					}
				}
			},
			"kind": "dev",
			"methods": {
				"checkAccess(address,bytes32)": {
					"params": {
						"deviceId": "Device identifier",
						"user": "Wallet address of the session owner"
					},
					"returns": {
						"active": "  Whether access is currently valid",
						"expiresAt": "Unix timestamp of expiry (0 if not active)"
					}
				},
				"extendAccess(bytes32,uint256)": {
					"params": {
						"deviceId": "The device to extend access for",
						"tierId": "Tier to extend by"
					}
				},
				"getAllTiers()": {
					"returns": {
						"tiers": " Array of all tiers"
