		"devdoc": {
			"custom:security-contact": "security@yourprotocol.xyz",
			"details": "Security properties:      - ReentrancyGuard: prevents re-entrancy on all payable functions      - Pausable: owner can halt all purchases in an emergency      - Ownable2Step: two-step ownership transfer prevents accidental owner loss      - Pull-over-push: ETH is accumulated; owner explicitly calls withdraw()      - Checks-Effects-Interactions: state is written to registry BEFORE emitting events      - No floating-point: all time/price calculations use integer arithmetic",
			"errors": {
				"EnforcedPause()": [
					{
						"details": "The operation failed because the contract is paused."
					}
				],
				"ExpectedPause()": [
					{
						"details": "The operation failed because the contract is not paused."
					}
				],
				"OwnableInvalidOwner(address)": [
					{
						"details": "The owner is not a valid owner account. (eg. `address(0)`)"
					}
				],
				"OwnableUnauthorizedAccount(address)": [
					{
						"details": "The caller account is not authorized to perform an operation."
					}
				],
				"ReentrancyGuardReentrantCall()": [
					{
						"details": "Unauthorized reentrant call."
					}
				]
			},
			"events": {
				"AccessGranted(address,bytes32,uint256,uint256,uint256)": {
					"params": {
						"amountPaid": "ETH paid in wei",
						"deviceId": "Off-chain identifier (MAC address hash, device fingerprint)",
						"expiresAt": "Block timestamp when access expires",
						"tierId": "The pricing tier selected",
						"user": "The wallet address purchasing access"
					}
				},
				"Paused(address)": {
					"details": "Emitted when the pause is triggered by `account`."
				},
				"Unpaused(address)": {
					"details": "Emitted when the pause is lifted by `account`."
				}
			},
