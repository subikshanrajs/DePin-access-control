		"userdoc": {
			"events": {
				"AccessExtended(address,bytes32,uint256,uint256)": {
					"notice": "Emitted when a session is extended"
				},
				"AccessGranted(address,bytes32,uint256,uint256,uint256)": {
					"notice": "Emitted when a new access session is granted"
				},
				"AccessRevoked(address,bytes32)": {
					"notice": "Emitted when a session is explicitly revoked by the owner"
				},
				"EmergencyPause(bool)": {
					"notice": "Emitted when the contract is paused/unpaused"
				},
				"TierUpdated(uint256,uint256,uint256)": {
					"notice": "Emitted when a pricing tier is created or updated"
				},
				"Withdrawn(address,uint256)": {
					"notice": "Emitted when accumulated ETH is withdrawn"
				}
			},
			"kind": "user",
			"methods": {
				"addTier(uint256,uint256,string)": {
					"notice": "Add a new pricing tier"
				},
				"checkAccess(address,bytes32)": {
					"notice": "Check if a device currently has valid access"
				},
				"deactivateTier(uint256)": {
					"notice": "Disable a tier without deleting it (preserves tierId indices)"
				},
				"extendAccess(bytes32,uint256)": {
					"notice": "Extend an existing (or just-expired) session.         Adds the tier's duration on top of the current expiry if still active,         or from block.timestamp if already expired."
				},
				"getAllTiers()": {
					"notice": "Get all active tiers"
				},
				"getTier(uint256)": {
					"notice": "Get tier details"
				},
				"purchaseAccess(bytes32,uint256)": {
					"notice": "Purchase a new access session for a device.         The user sends ETH; if access is already active, the call reverts.         Use extendAccess() to top-up a live session."
				},
				"registry()": {
					"notice": "The session data store (separate contract for upgradeability)"
				},
				"remainingTime(address,bytes32)": {
					"notice": "Returns remaining seconds of access for a device"
				},
				"revokeAccess(address,bytes32)": {
					"notice": "Revoke access for a device (owner only, emergency use)"
				},
				"setTreasury(address)": {
					"notice": "Update the treasury address"
				},
				"tierCount()": {
					"notice": "How many tiers exist"
				},
				"togglePause()": {
					"notice": "Toggle emergency pause"
				},
				"totalRevenue()": {
					"notice": "Accumulated protocol revenue (wei). Tracks what can be withdrawn."
				},
				"treasury()": {
					"notice": "Address that receives withdrawn ETH (treasury / multisig)"
				},
				"updateTier(uint256,uint256,uint256,bool,string)": {
					"notice": "Update an existing tier"
				},
				"withdraw()": {
					"notice": "Withdraw accumulated ETH to treasury"
				}
			},
			"notice": "Production-grade time-boxed network access protocol for Arbitrum.         Users pay ETH to unlock a device/network for a fixed time window.         An off-chain IoT worker listens to emitted events and configures         physical hardware (routers, RADIUS servers, etc.) accordingly.",
