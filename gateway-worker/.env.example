# ============================================================
# DePIN Gateway Worker — Environment Configuration
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ---- Blockchain RPC ----------------------------------------
# Arbitrum Sepolia (testnet):
RPC_URL=https://sepolia-rollup.arbitrum.io/rpc
# Arbitrum One (mainnet):
# RPC_URL=https://arb1.arbitrum.io/rpc

# ---- Contract Addresses (from deployments/latest.json) -----
ACCESS_GATEWAY_ADDRESS=0xYourAccessGatewayAddressHere
SESSION_REGISTRY_ADDRESS=0xYourSessionRegistryAddressHere

# ---- Worker Configuration ----------------------------------
# How often to poll for expired sessions (ms). 
# Complement to event-driven approach — catches any missed events.
POLL_INTERVAL_MS=30000

# Block confirmations to wait before acting on an event.
# Higher = more security, slower response. 1 is fine for Arbitrum (fast finality).
BLOCK_CONFIRMATIONS=1

# Starting block for event indexing (set to deployment block to skip old history)
START_BLOCK=0

# ---- Router / Hardware Backend -----------------------------
# Options: openwrt | radius | hostapd | simulation
ROUTER_BACKEND=simulation

# OpenWrt router configuration (if ROUTER_BACKEND=openwrt)
OPENWRT_HOST=192.168.1.1
OPENWRT_USER=root
OPENWRT_PASSWORD=your_router_password
OPENWRT_INTERFACE=wlan0

# RADIUS server configuration (if ROUTER_BACKEND=radius)
RADIUS_HOST=127.0.0.1
RADIUS_PORT=1812
RADIUS_SECRET=testing123
RADIUS_ACCOUNTING_PORT=1813

# ---- Prometheus Metrics (optional) -------------------------
METRICS_PORT=9090

# ---- Logging -----------------------------------------------
# debug | info | warn | error
LOG_LEVEL=info